#!/bin/bash
# vaf — Vitalinux Autoregistration Federated
#
# Daemon que combina VAC y VAL:
#
#   Como VAC: se registra en UPPER_VAS_HOST con su propio UUID, heartbeat
#             periódico y selfcheck de identidad (hostname/IP/MAC). Verifica
#             su registro con GET /clients/{uuid} (refresh_upper_identity).
#
#   Como VAL: monitoriza LOCAL_VAS_HOST; cuando el inventario local cambia
#             (GET /version), descarga GET /clients con FILTER (status) y
#             GLOBAL_KEY (extra_key), y actualiza extra_imperative.VAF_<KEY>
#             en el VAS superior.
#
#   Con SYNC_UPPER=true: descarga también el inventario del VAS superior en
#             /var/lib/vaf/upper_clients.json para consumo local.
#
# Journalctl: journalctl -u vaf -f
#   Filtrar errores: journalctl -u vaf | grep '\[VAF-ERROR\]'

set -euo pipefail

LOG_TAG="[VAF]"
source /usr/lib/vaf/vaf-common.sh

# ---------------------------------------------------------------------------
# Inicialización
# ---------------------------------------------------------------------------
load_all_conf

mkdir -p "$STATE_DIR"

if [[ ! -f "$ID_FILE" ]]; then
    uuidgen > "$ID_FILE"
    chmod 600 "$ID_FILE"
    log "UUID generado: $(cat "$ID_FILE")"
fi

[[ ! -f "$VERSION_FILE"       ]] && echo "0" > "$VERSION_FILE"
[[ ! -f "$UPPER_VERSION_FILE" ]] && echo "0" > "$UPPER_VERSION_FILE"

CLIENT_ID="$(tr -d '[:space:]' < "$ID_FILE")"

if [[ -z "$KEY" ]]; then
    log "ERROR: KEY no está definida en vaf.conf. Abortando."
    exit 1
fi

case "$FILTER" in
    active|inactive|archived|all) ;;
    *)
        log "ERROR: FILTER inválido: '$FILTER'. Valores válidos: active, inactive, archived, all."
        exit 1
        ;;
esac

log "=== Iniciando VAF ==="
log "KEY:             VAF_${KEY}"
log "LOCAL_VAS_HOST:  $LOCAL_VAS_HOST"
log "UPPER_VAS_HOST:  ${UPPER_VAS_HOST:-(no definido)}"
log "FILTER:          $FILTER"
log "GLOBAL_KEY:      ${GLOBAL_KEY:-(ninguna)}"
log "CHECK:           ${CHECK_SECONDS}s"
log "RETRY:           ${RETRY_SECONDS}s"
log "SYNC_UPPER:      $SYNC_UPPER"
log "BUMP_LISTEN_PORT:${BUMP_LISTEN_PORT} ($([ "$BUMP_LISTEN_PORT" != "0" ] && echo 'activo' || echo 'desactivado'))"
log "UUID:            $CLIENT_ID"

# Variables de ciclo
LOC_HOST=""
LOC_IP=""
LOC_MAC=""

# ---------------------------------------------------------------------------
# Bump listener (notificación push desde VAS local, como VAL-Aware)
# ---------------------------------------------------------------------------
BUMP_PID=""
BUMP_FIFO="/var/run/vaf/bump.fifo"

interruptible_sleep() {
    if [[ "$BUMP_LISTEN_PORT" != "0" ]]; then
        read -t "$1" -r _bump <&3 2>/dev/null || true
    else
        sleep "$1"
    fi
}

cleanup() {
    [[ -n "$BUMP_PID" ]] && kill "$BUMP_PID" 2>/dev/null || true
    [[ -e "$BUMP_FIFO" ]] && rm -f "$BUMP_FIFO" || true
    exit 0
}
trap cleanup SIGTERM SIGINT

if [[ "$BUMP_LISTEN_PORT" != "0" ]]; then
    mkdir -p "$(dirname "$BUMP_FIFO")"
    mkfifo "$BUMP_FIFO" 2>/dev/null || true
    exec 3<>"$BUMP_FIFO"
    nc -u -l -k -p "$BUMP_LISTEN_PORT" >"$BUMP_FIFO" &
    BUMP_PID=$!
    log "[BUMP] Escuchando UDP en puerto $BUMP_LISTEN_PORT (PID $BUMP_PID)"
fi

# ---------------------------------------------------------------------------
# Fase de arranque: esperar UPPER_VAS_HOST y registro inicial bloqueante
# ---------------------------------------------------------------------------
while [[ -z "$UPPER_VAS_HOST" ]]; do
    log "UPPER_VAS_HOST no definido. Esperando ${RETRY_SECONDS}s."
    sleep "$RETRY_SECONDS"
    load_all_conf
done

log "[STARTUP] Registrando nodo en VAS superior (fase inicial)..."

if fetch_local_clients; then
    STARTUP_EXTRA="$(build_vaf_extra)"
else
    STARTUP_EXTRA=""
    log "[STARTUP] Inventario local no disponible. Registrando sin sobrescribir VAF_${KEY} existente."
fi

while true; do
    LOC_HOST="$(get_hostname)"
    LOC_IP="$(get_ip)"
    LOC_MAC="$(get_mac)"

    if register_client "$LOC_HOST" "$LOC_IP" "$LOC_MAC" "$STARTUP_EXTRA" "" > /dev/null; then
        save_identity "$LOC_HOST" "$LOC_IP" "$LOC_MAC" "$STARTUP_EXTRA" ""
        log "[STARTUP] Registro inicial completado."

        # Confirmar con GET /clients/{uuid} que el VAS superior almacenó el extra
        refresh_upper_identity || log "[STARTUP] No se pudo refrescar identity desde UPPER_VAS."

        # Guardar versión local actual para no repetir sincronización en el primer ciclo
        local_ver="$(get_local_version)"
        if [[ -n "$local_ver" && "$local_ver" =~ ^[0-9]+$ ]]; then
            echo "$local_ver" > "$VERSION_FILE"
            log "[STARTUP] Versión local inicializada: $local_ver"
        fi

        if [[ "$SYNC_UPPER" == "true" ]]; then
            download_upper_clients || log "[STARTUP] Inventario superior no disponible aún."
            upper_ver="$(get_upper_version)"
            [[ -n "$upper_ver" && "$upper_ver" =~ ^[0-9]+$ ]] && echo "$upper_ver" > "$UPPER_VERSION_FILE"
        fi
        break
    fi
    log "[STARTUP] No se pudo contactar con VAS superior. Reintentando en ${RETRY_SECONDS}s."
    sleep "$RETRY_SECONDS"
done

# ---------------------------------------------------------------------------
# Bucle principal
# ---------------------------------------------------------------------------
while true; do
    cycle_start="$(date -u '+%Y-%m-%d %H:%M:%S UTC')"
    log_debug "--- Ciclo iniciado: $cycle_start ---"

    # --- Paso 1: Recopilar identidad propia ----------------------------------
    LOC_HOST="$(get_hostname)"
    LOC_IP="$(get_ip)"
    LOC_MAC="$(get_mac)"

    # Extra actualmente en identity.json (para heartbeat sin re-fetch del inventario)
    # "" = COALESCE (conservar lo que ya hay en el VAS superior)
    if load_identity; then
        CURRENT_IMP="$IDENTITY_IMP"
    else
        CURRENT_IMP=""
    fi

    # --- Paso 2: Selfcheck de identidad + heartbeat o registro ---------------
    needs_register=false

    if selfcheck_local; then
        if ! heartbeat_client; then
            log "[HEARTBEAT] Sin respuesta o nodo no registrado — re-registrando."
            needs_register=true
        fi
    else
        needs_register=true
    fi

    if [[ "$needs_register" == "true" ]]; then
        if ! register_client "$LOC_HOST" "$LOC_IP" "$LOC_MAC" "$CURRENT_IMP" "" > /dev/null; then
            log "[VAF-ERROR] No se pudo contactar con VAS superior. Reintentando en ${RETRY_SECONDS}s."
            sleep "$RETRY_SECONDS"
            continue
        fi
        save_identity "$LOC_HOST" "$LOC_IP" "$LOC_MAC" "$CURRENT_IMP" ""
        refresh_upper_identity || log "[IDENTITY] No se pudo refrescar identity desde UPPER_VAS."
    fi

    # --- Paso 3: Comprobar versión del VAS local (como VAL) ------------------
    local_version="$(tr -d '[:space:]' < "$VERSION_FILE")"
    log_debug "[LOCAL-VER] Versión local guardada: $local_version"

    remote_local_version="$(get_local_version)"

    if [[ -z "$remote_local_version" ]]; then
        log "[VAF-ERROR] No se pudo obtener versión de VAS local. Reintentando en ${RETRY_SECONDS}s."
        sleep "$RETRY_SECONDS"
        continue
    fi

    if [[ ! "$remote_local_version" =~ ^[0-9]+$ ]]; then
        log "[VAF-ERROR] Versión local inválida: '$remote_local_version'. Reintentando en ${RETRY_SECONDS}s."
        sleep "$RETRY_SECONDS"
        continue
    fi

    if [[ "$remote_local_version" != "$local_version" ]]; then
        log "[SYNC] Cambio en VAS local: $local_version → $remote_local_version"

        if fetch_local_clients; then
            NEW_IMP="$(build_vaf_extra)"
            log_debug "[SYNC] Actualizando VAF_${KEY} en VAS superior..."
            if register_client "$LOC_HOST" "$LOC_IP" "$LOC_MAC" "$NEW_IMP" "" > /dev/null; then
                save_identity "$LOC_HOST" "$LOC_IP" "$LOC_MAC" "$NEW_IMP" ""
                echo "$remote_local_version" > "$VERSION_FILE"
                log "[SYNC] VAF_${KEY} actualizado. Versión local: $remote_local_version"
                # Verificar que el VAS superior almacenó correctamente el extra
                refresh_upper_identity || log "[IDENTITY] No se pudo verificar el extra en UPPER_VAS."
            else
                log "[VAF-ERROR] No se pudo actualizar en VAS superior. Reintentando en ${RETRY_SECONDS}s."
                sleep "$RETRY_SECONDS"
                continue
            fi
        else
            log "[VAF-ERROR] No se pudo descargar inventario local. Reintentando en ${RETRY_SECONDS}s."
            sleep "$RETRY_SECONDS"
            continue
        fi
    else
        log_debug "[LOCAL-VER] Sin cambios en VAS local ($local_version)."
    fi

    # --- Paso 4: Comprobar versión del VAS superior (SYNC_UPPER) -------------
    if [[ "$SYNC_UPPER" == "true" ]]; then
        upper_version="$(tr -d '[:space:]' < "$UPPER_VERSION_FILE")"
        remote_upper_version="$(get_upper_version)"

        if [[ -n "$remote_upper_version" && "$remote_upper_version" =~ ^[0-9]+$ ]]; then
            if [[ "$remote_upper_version" != "$upper_version" ]]; then
                log "[UPPER] Nueva versión en VAS superior: $upper_version → $remote_upper_version"
                if download_upper_clients; then
                    echo "$remote_upper_version" > "$UPPER_VERSION_FILE"
                fi
            else
                log_debug "[UPPER] Sin cambios en VAS superior ($upper_version)."
            fi
        fi
    fi

    log_debug "--- Ciclo completado. Próxima comprobación en ${CHECK_SECONDS}s. ---"
    interruptible_sleep "$CHECK_SECONDS"
done
