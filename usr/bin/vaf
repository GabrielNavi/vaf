#!/bin/bash
# vaf — Versatile Autoregistration Federated
#
# Daemon que combina VAC y VAL para federar un VAS local en una jerarquía.
# Requiere VAS instalado en el mismo host.
#
#   Rol VAL: monitoriza LOCAL_VAS; cuando el inventario cambia descarga
#            GET /clients, materializa LOCAL_KEY_LIST y dispara hooks_local.d/.
#
#   Rol VAC: se registra en UPPER_VAS_HOST con su propio UUID; publica el
#            inventario local como extra_imperative.VAF_<KEY>_clients, añade
#            extras de extras_imperative.d/ y extras_informative.d/, y mantiene
#            heartbeat periódico.
#
# Journalctl: journalctl -u vaf -f
#   Filtrar errores: journalctl -u vaf | grep '\[VAF-ERROR\]'

set -euo pipefail

LOG_TAG="[VAF]"
source /usr/lib/vaf/vaf-common.sh

# ---------------------------------------------------------------------------
# Inicialización
# ---------------------------------------------------------------------------
load_all_conf

mkdir -p "$STATE_DIR"

if [[ ! -f "$ID_FILE" ]]; then
    uuidgen > "$ID_FILE"
    chmod 600 "$ID_FILE"
    log "UUID generado: $(cat "$ID_FILE")"
fi

[[ ! -f "$VERSION_FILE"       ]] && echo "0" > "$VERSION_FILE"
[[ ! -f "$UPPER_VERSION_FILE" ]] && echo "0" > "$UPPER_VERSION_FILE"

CLIENT_ID="$(tr -d '[:space:]' < "$ID_FILE")"

_uuid_valid_re='^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$'
if [[ ! "$CLIENT_ID" =~ $_uuid_valid_re ]]; then
    log "[WARN] UUID inválido en $ID_FILE ('$CLIENT_ID'). Regenerando..."
    uuidgen > "$ID_FILE"
    chmod 600 "$ID_FILE"
    CLIENT_ID="$(tr -d '[:space:]' < "$ID_FILE")"
    log "UUID regenerado: $CLIENT_ID"
fi

case "$FILTER" in
    active|inactive|archived|all) ;;
    *)
        log "ERROR: FILTER inválido: '$FILTER'. Valores válidos: active, inactive, archived, all."
        exit 1
        ;;
esac

log "=== Iniciando VAF ==="
log "KEY:              VAF_${KEY}_clients"
log "LOCAL_VAS_HOST:   $LOCAL_VAS_HOST"
log "UPPER_VAS_HOST:   ${UPPER_VAS_SCHEME}://${UPPER_VAS_HOST:-(no definido)}"
log "FILTER:           $FILTER"
log "GLOBAL_KEY:       ${GLOBAL_KEY:-(ninguna)}"
log "LOCAL_KEY_LIST:   ${LOCAL_KEY_LIST:-(ninguna)}"
log "CHECK:            ${CHECK_SECONDS}s"
log "HEARTBEAT:        ${HEARTBEAT_SECONDS}s"
log "RETRY:            ${RETRY_SECONDS}s"
log "EXTRAS:           $EXTRAS_ENABLED"
log "SYNC_UPPER:       $SYNC_UPPER"
log "UUID:             $CLIENT_ID"

# Variables de ciclo
LOC_HOST=""
LOC_IP=""
LOC_MAC=""
EXTRA_IMP_BASE=""
EXTRA_INF=""

cleanup() { exit 0; }
trap cleanup SIGTERM SIGINT

# ---------------------------------------------------------------------------
# Arranque: esperar UPPER_VAS y registro inicial bloqueante
# ---------------------------------------------------------------------------
while [[ -z "$UPPER_VAS_HOST" ]]; do
    log "UPPER_VAS_HOST no definido. Esperando ${RETRY_SECONDS}s."
    sleep "$RETRY_SECONDS"
    load_all_conf
    [[ -n "$UPPER_VAS_HOST" ]] && \
        log "UPPER_VAS_HOST resuelto: ${UPPER_VAS_SCHEME}://${UPPER_VAS_HOST}"
done

log "[STARTUP] Registro inicial en VAS superior..."

LOC_HOST="$(get_hostname)"
LOC_IP="$(get_ip)"
LOC_MAC="$(get_mac)"

collect_extras_imperative
if fetch_local_clients; then
    STARTUP_IMP="$(build_vaf_extra "$EXTRA_IMP_BASE")"
    if [[ "$USE_VAT" == "true" && -n "$VAT_PRESET" ]] && command -v vat-operate &>/dev/null; then
        STARTUP_IMP="$(echo "$STARTUP_IMP" | vat-operate \
            --source-component VAF --direction upstream \
            --preset "$VAT_PRESET" 2>/dev/null)" \
        && log "[VAT] Extra de arranque saneado (upstream) con preset '$VAT_PRESET'" \
        || log "[VAT-WARN] vat-operate falló en arranque. Extra sin sanear."
    fi
else
    STARTUP_IMP="$(build_vaf_extra "$EXTRA_IMP_BASE")"
    log "[STARTUP] Inventario local no disponible. Registrando sin VAF_${KEY}_clients actual."
fi

while true; do
    if register_client "$LOC_HOST" "$LOC_IP" "$LOC_MAC" "$STARTUP_IMP" "" > /dev/null; then
        save_identity "$LOC_HOST" "$LOC_IP" "$LOC_MAC" "$STARTUP_IMP" "" \
            || log "[WARN] No se pudo guardar identity.json; continuando."
        log "[STARTUP] Registro inicial completado."
        refresh_upper_identity || log "[STARTUP] No se pudo refrescar identity desde UPPER_VAS."

        local_ver="$(get_local_version)"
        if [[ -n "$local_ver" && "$local_ver" =~ ^[0-9]+$ ]]; then
            write_version "$local_ver"
            log "[STARTUP] Versión local inicializada: $local_ver"
        fi

        if [[ "$SYNC_UPPER" == "true" ]]; then
            download_upper_clients || log "[STARTUP] Inventario superior no disponible aún."
            upper_ver="$(get_upper_version)"
            [[ -n "$upper_ver" && "$upper_ver" =~ ^[0-9]+$ ]] && write_upper_version "$upper_ver"
        fi
        break
    fi
    log "[STARTUP] No se pudo contactar con VAS superior. Reintentando en ${RETRY_SECONDS}s."
    sleep "$RETRY_SECONDS"
done

# ---------------------------------------------------------------------------
# Temporizadores
# ---------------------------------------------------------------------------
LAST_CHECK_TS=$(date +%s)
LAST_HB_TS=$(date +%s)
if (( CHECK_SECONDS <= HEARTBEAT_SECONDS )); then
    SLEEP_INTERVAL=$CHECK_SECONDS
else
    SLEEP_INTERVAL=$HEARTBEAT_SECONDS
fi
log "SLEEP_BASE: ${SLEEP_INTERVAL}s"

# ---------------------------------------------------------------------------
# Bucle principal
# ---------------------------------------------------------------------------
while true; do
    now=$(date +%s)

    LOC_HOST="$(get_hostname)"
    LOC_IP="$(get_ip)"
    LOC_MAC="$(get_mac)"

    # --- Bloque CHECK: versión LOCAL_VAS + extras imperativos (cada CHECK_SECONDS) ---
    if (( now - LAST_CHECK_TS >= CHECK_SECONDS )); then
        log_debug "--- CHECK: $(date -u '+%Y-%m-%d %H:%M:%S UTC') ---"

        # Extras imperativos del usuario
        collect_extras_imperative

        # Versión VAS local
        local_version="$(tr -d '[:space:]' < "$VERSION_FILE" 2>/dev/null || echo "0")"
        remote_local_version="$(get_local_version)"

        if [[ -z "$remote_local_version" ]]; then
            log "[VAF-ERROR] No se pudo obtener versión de VAS local. Reintentando en ${RETRY_SECONDS}s."
            sleep "$RETRY_SECONDS"
            continue
        fi
        if [[ ! "$remote_local_version" =~ ^[0-9]+$ ]]; then
            log "[VAF-ERROR] Versión local inválida: '$remote_local_version'."
            sleep "$RETRY_SECONDS"
            continue
        fi

        local_changed=false
        if [[ "$remote_local_version" != "$local_version" ]]; then
            local_changed=true
            log "[SYNC] Cambio en VAS local: $local_version → $remote_local_version"

            if ! fetch_local_clients; then
                log "[VAF-ERROR] No se pudo descargar inventario local. Reintentando en ${RETRY_SECONDS}s."
                sleep "$RETRY_SECONDS"
                continue
            fi
            materialize_keys
            dispatch_hooks_local "$remote_local_version"
            write_version "$remote_local_version"
        else
            log_debug "[LOCAL-VER] Sin cambios en VAS local ($local_version)."
        fi

        # Construir extra_imperative completo (VAF_KEY_clients + extras usuario)
        NEW_IMP="$(build_vaf_extra "$EXTRA_IMP_BASE")"

        if [[ "$USE_VAT" == "true" && -n "$VAT_PRESET" ]] && command -v vat-operate &>/dev/null; then
            NEW_IMP="$(echo "$NEW_IMP" | vat-operate \
                --source-component VAF --direction upstream \
                --preset "$VAT_PRESET" 2>/dev/null)" \
            || log "[VAT-WARN] vat-operate falló. Extra sin sanear."
        fi

        # Registrar si la versión cambió o si la identidad/extras cambiaron
        if $local_changed || ! selfcheck_imp "$NEW_IMP"; then
            log_debug "[SYNC] Actualizando registro en VAS superior..."
            if register_client "$LOC_HOST" "$LOC_IP" "$LOC_MAC" "$NEW_IMP" "" > /dev/null; then
                save_identity "$LOC_HOST" "$LOC_IP" "$LOC_MAC" "$NEW_IMP" "" \
                    || log "[WARN] No se pudo guardar identity.json; continuando."
                refresh_upper_identity || log "[IDENTITY] No se pudo verificar el extra en UPPER_VAS."
                LAST_HB_TS=$now
            else
                log "[VAF-ERROR] No se pudo actualizar en VAS superior. Reintentando en ${RETRY_SECONDS}s."
                sleep "$RETRY_SECONDS"
                continue
            fi
        fi

        # SYNC_UPPER: descargar inventario del VAS superior si cambió
        if [[ "$SYNC_UPPER" == "true" ]]; then
            upper_version="$(tr -d '[:space:]' < "$UPPER_VERSION_FILE" 2>/dev/null || echo "0")"
            remote_upper_version="$(get_upper_version)"
            if [[ -n "$remote_upper_version" && "$remote_upper_version" =~ ^[0-9]+$ ]]; then
                if [[ "$remote_upper_version" != "$upper_version" ]]; then
                    log "[UPPER] Nueva versión en VAS superior: $upper_version → $remote_upper_version"
                    download_upper_clients && write_upper_version "$remote_upper_version"
                else
                    log_debug "[UPPER] Sin cambios en VAS superior ($upper_version)."
                fi
            fi
        fi

        LAST_CHECK_TS=$now
    fi

    # --- Bloque HEARTBEAT: extras informativos + liveness UPPER_VAS ---
    if (( now - LAST_HB_TS >= HEARTBEAT_SECONDS )); then
        log_debug "--- HEARTBEAT: $(date -u '+%Y-%m-%d %H:%M:%S UTC') ---"

        # Extras informativos del usuario
        collect_extras_informative

        # Selfcheck identidad (host/ip/mac)
        if ! selfcheck_local; then
            load_identity || true
            if register_client "$LOC_HOST" "$LOC_IP" "$LOC_MAC" \
                    "${IDENTITY_IMP:-}" "$EXTRA_INF" > /dev/null; then
                save_identity "$LOC_HOST" "$LOC_IP" "$LOC_MAC" \
                    "${IDENTITY_IMP:-}" "$EXTRA_INF" \
                    || log "[WARN] No se pudo guardar identity.json; continuando."
                refresh_upper_identity || log "[IDENTITY] No se pudo refrescar identity."
            else
                log "[VAF-ERROR] No se pudo contactar con VAS superior. Reintentando en ${RETRY_SECONDS}s."
                sleep "$RETRY_SECONDS"
                continue
            fi
        elif [[ -n "$EXTRA_INF" ]]; then
            # Informative cambió o existe: registrar sin tocar IMP (COALESCE)
            load_identity || true
            local_inf="${IDENTITY_INF:-}"
            if [[ "$EXTRA_INF" != "$local_inf" ]]; then
                log_debug "[HEARTBEAT] extra_informative cambió — actualizando."
                register_client "$LOC_HOST" "$LOC_IP" "$LOC_MAC" \
                    "" "$EXTRA_INF" > /dev/null \
                && save_identity "$LOC_HOST" "$LOC_IP" "$LOC_MAC" \
                    "${IDENTITY_IMP:-}" "$EXTRA_INF" \
                || log "[WARN] No se pudo actualizar extra_informative."
            else
                if ! heartbeat_client; then
                    log "[HEARTBEAT] Sin respuesta — re-registrando."
                    load_identity || true
                    if register_client "$LOC_HOST" "$LOC_IP" "$LOC_MAC" \
                            "${IDENTITY_IMP:-}" "$EXTRA_INF" > /dev/null; then
                        save_identity "$LOC_HOST" "$LOC_IP" "$LOC_MAC" \
                            "${IDENTITY_IMP:-}" "$EXTRA_INF" \
                            || log "[WARN] No se pudo guardar identity.json; continuando."
                        refresh_upper_identity || log "[IDENTITY] No se pudo refrescar identity."
                    else
                        log "[VAF-ERROR] No se pudo contactar con VAS superior. Reintentando en ${RETRY_SECONDS}s."
                        sleep "$RETRY_SECONDS"
                        continue
                    fi
                fi
            fi
        else
            if ! heartbeat_client; then
                log "[HEARTBEAT] Sin respuesta — re-registrando."
                load_identity || true
                if register_client "$LOC_HOST" "$LOC_IP" "$LOC_MAC" \
                        "${IDENTITY_IMP:-}" "" > /dev/null; then
                    save_identity "$LOC_HOST" "$LOC_IP" "$LOC_MAC" \
                        "${IDENTITY_IMP:-}" "" \
                        || log "[WARN] No se pudo guardar identity.json; continuando."
                    refresh_upper_identity || log "[IDENTITY] No se pudo refrescar identity."
                else
                    log "[VAF-ERROR] No se pudo contactar con VAS superior. Reintentando en ${RETRY_SECONDS}s."
                    sleep "$RETRY_SECONDS"
                    continue
                fi
            fi
        fi

        LAST_HB_TS=$now
    fi

    log_debug "--- Próximo ciclo en ${SLEEP_INTERVAL}s ---"
    sleep "$SLEEP_INTERVAL"
done
