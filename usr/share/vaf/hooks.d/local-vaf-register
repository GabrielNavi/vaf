#!/bin/bash
# local-vaf-register — Hook para el VAS local.
#
# Instalado automáticamente en /etc/vas/hooks.d/ por el postinst de VAF.
#
# Cuando el VAS local ejecuta bump_version(), este hook llama a vaf-register
# (instancia principal) y a todas las sub-instancias habilitadas, que actualizan
# inmediatamente VAF_<KEY>_clients en sus respectivos VAS superiores.
# Así el VAS superior queda sincronizado en milisegundos, sin esperar al
# próximo ciclo del daemon vaf (CHECK_SECONDS).
#
# Requiere: vaf instalado en el mismo equipo que el VAS local.
# Variables de entorno inyectadas por VAS: VAS_VERSION, VAS_HOST.

set -euo pipefail

if ! command -v vaf-register >/dev/null 2>&1; then
    echo "[local-vaf-register] vaf-register no encontrado. ¿Está vaf instalado?" >&2
    exit 0
fi

vaf-register

for _sub_dir in /etc/vaf/vaf.sub/*/; do
    [ -f "${_sub_dir}.enabled" ] || continue
    vaf-register --instance "$(basename "$_sub_dir")"
done
