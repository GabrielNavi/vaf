#!/bin/sh
set -e

case "$1" in
    configure)
        mkdir -p /etc/vaf/vaf.conf.d \
                 /etc/vaf/hooks_local.d \
                 /etc/vaf/extras_imperative.d \
                 /etc/vaf/extras_informative.d \
                 /etc/vaf/vaf.sub \
                 /var/lib/vaf/sub \
                 /var/log/vaf

        if [ ! -f /etc/vaf/vaf-id ]; then
            uuidgen > /etc/vaf/vaf-id
            chmod 600 /etc/vaf/vaf-id
        fi

        # Instalación fresca: auto-instalar hook en VAS local
        if [ -z "${2:-}" ] && [ -d /etc/vas/hooks.d ]; then
            if [ ! -e /etc/vas/hooks.d/local-vaf-register ]; then
                ln -s /usr/share/vaf/hooks.d/local-vaf-register \
                      /etc/vas/hooks.d/local-vaf-register
            fi
        fi
        ;;
esac

#DEBHELPER#
